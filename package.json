{
  "name": "create-grafana-plugin",
  "version": "0.2.0",
  "description": "CLI tool to scaffold production-ready Grafana plugin projects with Rspack, bun, optional Rust WASM, Docker dev environment, and mock data generator.",
  "author": "andeya <andeyalee@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/andeya/create-grafana-plugin"
  },
  "keywords": [
    "grafana",
    "plugin",
    "scaffold",
    "create",
    "rspack",
    "wasm",
    "rust",
    "cli"
  ],
  "packageManager": "bun@1.3.11",
  "bin": {
    "create-grafana-plugin": "packaging/npm/create-grafana-plugin/bin/index.js"
  },
  "scripts": {
    "fmt": "bun run fmt:rust && bun run fmt:ts",
    "fmt:rust": "cargo fmt --all",
    "fmt:ts": "biome format --write scripts/ packaging/",
    "lint": "bun run lint:rust && bun run lint:ts",
    "lint:rust": "cargo fmt --all -- --check && cargo clippy --workspace --all-targets -- -D warnings",
    "lint:ts": "biome check scripts/ packaging/",
    "test": "cargo test --workspace",
    "verify": "bun run lint && bun run test",
    "bump": "bun scripts/bump-version.ts",
    "bump:patch": "bun scripts/bump-version.ts patch",
    "bump:minor": "bun scripts/bump-version.ts minor",
    "bump:major": "bun scripts/bump-version.ts major"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "bun-types": "^1.3.11"
  }
}
