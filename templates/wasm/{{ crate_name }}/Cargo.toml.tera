# @managed by create-grafana-plugin — do not edit
[package]
name = "{{ crate_name }}"
version = "1.0.0"
edition = "2021"
authors = ["{{ author }}"]
license = "MIT"

[lib]
crate-type = ["cdylib", "rlib"]

[dependencies]
wasm-bindgen = "0.2"
serde = { version = "1", features = ["derive"] }
serde_json = "1"
getrandom = { version = "0.2", features = ["js"] }

[lints]
workspace = true
